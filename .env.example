# Copy to .env.local (recommended) or .env, then restart Vite.
#
# Supabase dashboard: Project → Settings → API
#   - Project URL  -> VITE_SUPABASE_URL (must be https://<ref>.supabase.co)
#   - anon / publishable public key -> VITE_SUPABASE_ANON_KEY
#
# If login shows ERR_NAME_NOT_RESOLVED or "Failed to fetch", the hostname does not
# exist in DNS (wrong ref, paused project, or project deleted). Paste the current
# Project URL from the dashboard; do not guess the ref.
#
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Optional — only for scripts/push-remote-migrations.ps1 (database password from Dashboard → Settings → Database)
# SUPABASE_PROJECT_REF=your-project-ref
# SUPABASE_DB_PASSWORD=
